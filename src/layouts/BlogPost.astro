---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: var(--max-width-prose);
				max-width: calc(100% - 2.5em);
				margin: 0 auto;
				padding: 3em 1em 5em 1em;
				flex: 1;
			}
			.hero-image {
				margin: 0 0 2.5em 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 6px;
			}
			article {
				color: var(--color-text);
			}
			.title {
				margin-bottom: 2.5em;
				padding-bottom: 1.5em;
				border-bottom: 1px solid var(--color-border-soft);
			}
			.title h1 {
				margin: 0 0 0.6em 0;
				font-size: 1.85em;
				font-weight: 700;
				line-height: 1.35;
				letter-spacing: -0.01em;
			}
			.date {
				color: var(--color-text-muted);
				font-size: 0.85em;
				font-variant-numeric: tabular-nums;
			}
			.last-updated-on {
				font-style: italic;
				margin-top: 0.25em;
				color: var(--color-text-muted);
				font-size: 0.85em;
			}
			.prose {
				color: var(--color-text);
				font-size: 1em;
				line-height: 1.95;
			}
			.prose :global(h2) {
				margin-top: 2.2em;
				margin-bottom: 0.8em;
				font-size: 1.3em;
			}
			.prose :global(h3) {
				margin-top: 1.8em;
				margin-bottom: 0.6em;
				font-size: 1.1em;
			}
			.prose :global(p) {
				margin: 0 0 1.5em 0;
			}
			.prose :global(hr) {
				margin: 3em auto;
				width: 4em;
				background: var(--color-border);
				max-width: none;
			}
			.prose :global(blockquote) {
				margin: 2em 0;
				padding-left: 1.4em;
				color: var(--color-text-soft);
				border-left: 2px solid var(--color-accent);
			}
			.prose :global(img) {
				margin: 2em auto;
				display: block;
			}
			.back {
				margin-top: 4em;
				padding-top: 2em;
				border-top: 1px solid var(--color-border-soft);
				font-size: 0.9em;
			}
			.back a {
				text-decoration: none;
				color: var(--color-text-muted);
			}
			.back a:hover {
				color: var(--color-accent);
			}
			@media (max-width: 720px) {
				main { padding: 2em 1em 3em 1em; }
				.title h1 { font-size: 1.55em; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<Image width={1280} height={640} src={heroImage} alt="" />
						</div>
					)
				}
				<header class="title">
					<h1>{title}</h1>
					<div class="date">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<div class="last-updated-on">
									更新于 <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
				</header>
				<div class="prose">
					<slot />
				</div>
				<div class="back">
					<a href="/blog">← 返回文章列表</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
