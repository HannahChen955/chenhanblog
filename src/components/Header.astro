---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="inner">
		<a href="/" class="logo" aria-label={SITE_TITLE}>
			<img src="/logo.svg" alt="HAN" width="36" height="36" />
		</a>
		<nav>
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<HeaderLink href="/rss.xml">订阅</HeaderLink>
		</nav>
	</div>
</header>
<style>
	header {
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border-soft);
	}
	.inner {
		width: var(--max-width-page);
		max-width: calc(100% - 2.5em);
		margin: 0 auto;
		padding: 1em 1em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2em;
		flex-wrap: wrap;
	}
	.logo {
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		line-height: 0;
		transition: opacity 0.15s ease;
	}
	.logo:hover {
		opacity: 0.85;
	}
	.logo img {
		display: block;
		width: 36px;
		height: 36px;
	}
	nav {
		display: flex;
		gap: 1.6em;
		font-size: 0.92em;
	}
	nav :global(a) {
		color: var(--color-text-soft);
		text-decoration: none;
		padding: 0;
		border: none;
		font-weight: 400;
		transition: color 0.15s ease;
	}
	nav :global(a:hover) {
		color: var(--color-accent);
	}
	nav :global(a.active) {
		color: var(--color-text);
		text-decoration: none;
		border: none;
		font-weight: 500;
	}
	@media (max-width: 480px) {
		.inner {
			padding: 0.9em 1em;
			gap: 0.8em;
		}
		.logo img {
			width: 32px;
			height: 32px;
		}
		nav {
			gap: 1.1em;
			font-size: 0.88em;
		}
	}
</style>
