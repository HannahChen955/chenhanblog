---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = posts.slice(0, 8);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p class="kicker">写作空间 · Personal Notebook</p>
				<h1>你好，我是 Hannah。</h1>
				<p class="lede">
					这里是我自己的写作角落，记一些想法、感悟，
					以及那些容易被生活冲走的、值得留下的片段。
					<br />
					不追求完整，只希望能持续地写下去。
				</p>
			</section>

			<section class="posts">
				<header class="section-header">
					<h2>最近</h2>
					{posts.length > recent.length && (
						<a href="/blog" class="all-link">全部 →</a>
					)}
				</header>

				{recent.length === 0 ? (
					<p class="empty">第一篇正在路上。</p>
				) : (
					<ul>
						{recent.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-link">
									<div class="post-head">
										<span class="title">{post.data.title}</span>
										<span class="date">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									{post.data.description && (
										<p class="excerpt">{post.data.description}</p>
									)}
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
		<style>
			.intro {
				padding: 1em 0 3em 0;
				margin-bottom: 1em;
			}
			.kicker {
				font-size: 0.78em;
				color: var(--color-text-muted);
				letter-spacing: 0.12em;
				text-transform: uppercase;
				margin: 0 0 1.6em 0;
				font-weight: 500;
			}
			.intro h1 {
				font-size: 2em;
				margin: 0 0 0.7em 0;
				line-height: 1.3;
				letter-spacing: -0.015em;
			}
			.lede {
				font-size: 1.02em;
				color: var(--color-text-soft);
				margin: 0;
				line-height: 1.85;
				max-width: 36em;
			}

			.posts {
				border-top: 1px solid var(--color-border-soft);
				padding-top: 2.5em;
			}
			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 1.8em;
			}
			.section-header h2 {
				font-size: 0.85em;
				margin: 0;
				color: var(--color-text-muted);
				letter-spacing: 0.12em;
				text-transform: uppercase;
				font-weight: 500;
			}
			.all-link {
				font-size: 0.85em;
				color: var(--color-text-muted);
				text-decoration: none;
				letter-spacing: 0.05em;
			}
			.all-link:hover {
				color: var(--color-accent);
			}

			.posts ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.posts li {
				margin-bottom: 0.4em;
				padding-bottom: 1.6em;
				border-bottom: 1px solid var(--color-border-soft);
			}
			.posts li:last-child {
				border-bottom: none;
			}
			.post-link {
				display: block;
				text-decoration: none;
				color: var(--color-text);
				padding: 1em 0;
			}
			.post-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1.5em;
				margin-bottom: 0.4em;
			}
			.post-link .title {
				font-weight: 600;
				font-size: 1.05em;
				color: var(--color-text);
				transition: color 0.15s ease;
			}
			.post-link:hover .title {
				color: var(--color-accent);
			}
			.post-link .date {
				color: var(--color-text-muted);
				font-size: 0.82em;
				white-space: nowrap;
				font-variant-numeric: tabular-nums;
			}
			.post-link .excerpt {
				color: var(--color-text-soft);
				margin: 0.25em 0 0 0;
				font-size: 0.95em;
				line-height: 1.7;
			}

			.empty {
				color: var(--color-text-muted);
				font-style: italic;
			}

			@media (max-width: 520px) {
				.intro h1 {
					font-size: 1.65em;
				}
				.post-head {
					flex-direction: column;
					gap: 0.2em;
				}
			}
		</style>
	</body>
</html>
